generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime     @default(now())
  accounts      Account[]
  sessions      Session[]
  reviews       Review[]
  screenshots   Screenshot[]
  gamesAdded    Game[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Game {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  coverImage   String?
  description  String?
  releaseYear  Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  addedById    String
  addedBy      User         @relation(fields: [addedById], references: [id])
  reviews      Review[]
  screenshots  Screenshot[]
  tags         Tag[]        @relation("GameTags")
  genres       Genre[]      @relation("GameGenres")
}

model Review {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String
  score       Int
  status      ReviewStatus @default(DRAFT)
  publishDate DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  gameId      String
  game        Game         @relation(fields: [gameId], references: [id])
  authorId    String
  author      User         @relation(fields: [authorId], references: [id])
}

model Screenshot {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  createdAt DateTime @default(now())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  games Game[] @relation("GameTags")
}

model Genre {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  games Game[] @relation("GameGenres")
}

enum ReviewStatus {
  DRAFT
  PUBLISHED
}
